# ------------------------------
# OS / editor artifacts
# ------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ------------------------------
# Environment / secrets
# ------------------------------
.env
.env.*
!.env.example
*.local
*.secret
*.secrets

# ------------------------------
# TLS certs and private keys (generated)
# ------------------------------
certs/*.crt
certs/*.key
certs/*.pem
certs/*.p12
certs/*.pfx
!certs/curl-format.txt

# ------------------------------
# Generated benchmark outputs
# ------------------------------
results/*
!results/.gitkeep
!results/RESULTS_TEMPLATE.md
!results/trends/
!results/trends/*.csv

# ------------------------------
# Python cache / virtualenv
# ------------------------------
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# ------------------------------
# Runtime logs / temp files
# ------------------------------
*.log
*.pid
*.tmp
*.out

# ------------------------------
# Local docker overrides
# ------------------------------
docker-compose.override.yml
